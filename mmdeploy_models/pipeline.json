{
    "pipeline": {
        "input": [
            "img"
        ],
        "output": [
            "post_output"
        ],
        "tasks": [
            {
                "type": "Task",
                "module": "Transform",
                "name": "Preprocess",
                "input": [
                    "img"
                ],
                "output": [
                    "prep_output"
                ],
                "transforms": [
                    {
                        "type": "LoadImageFromFile"
                    },
                    {
                        "keep_ratio": true,
                        "type": "Resize",
                        "size": [
                            2048,
                            512
                        ]
                    },
                    {
                        "type": "Normalize",
                        "mean": [
                            123.675,
                            116.28,
                            103.53
                        ],
                        "std": [
                            58.395,
                            57.12,
                            57.375
                        ],
                        "to_rgb": true
                    },
                    {
                        "type": "ImageToTensor",
                        "keys": [
                            "img"
                        ]
                    },
                    {
                        "type": "Collect",
                        "keys": [
                            "img"
                        ],
                        "meta_keys": [
                            "img_shape",
                            "pad_shape",
                            "ori_shape",
                            "img_norm_cfg",
                            "scale_factor"
                        ]
                    }
                ]
            },
            {
                "name": "clipguide",
                "type": "Task",
                "module": "Net",
                "is_batched": true,
                "input": [
                    "prep_output"
                ],
                "output": [
                    "infer_output"
                ],
                "input_map": {
                    "img": "input"
                },
                "output_map": {}
            },
            {
                "type": "Task",
                "module": "mmseg",
                "name": "postprocess",
                "component": "ResizeMask",
                "params": {
                    "act_cfg": {
                        "type": "ReLU"
                    },
                    "align_corners": false,
                    "class_json": "data/tp.json",
                    "clip_dim": 512,
                    "clip_pretrained": "ViT-B/32",
                    "in_channels": 256,
                    "loss_decode": [
                        {
                            "class_weight": [
                                1.0,
                                2.0,
                                5.0
                            ],
                            "loss_weight": 0.6,
                            "type": "FocalLoss",
                            "use_sigmoid": true
                        },
                        {
                            "loss_weight": 0.4,
                            "type": "DiceLoss",
                            "use_sigmoid": true
                        },
                        {
                            "loss_weight": 0.2,
                            "per_image": true,
                            "type": "LovaszLoss"
                        }
                    ],
                    "num_classes": 3,
                    "prompt_ensemble_type": "single",
                    "transformer_decoder": {
                        "init_cfg": null,
                        "layer_cfg": {
                            "cross_attn_cfg": {
                                "attn_drop": 0.1,
                                "batch_first": true,
                                "dropout_layer": null,
                                "embed_dims": 256,
                                "num_heads": 8,
                                "proj_drop": 0.1
                            },
                            "ffn_cfg": {
                                "act_cfg": {
                                    "inplace": true,
                                    "type": "ReLU"
                                },
                                "add_identity": true,
                                "dropout_layer": null,
                                "embed_dims": 256,
                                "feedforward_channels": 2048,
                                "ffn_drop": 0.1,
                                "num_fcs": 2
                            },
                            "self_attn_cfg": {
                                "attn_drop": 0.1,
                                "batch_first": true,
                                "dropout_layer": null,
                                "embed_dims": 256,
                                "num_heads": 8,
                                "proj_drop": 0.1
                            }
                        },
                        "num_layers": 3,
                        "return_intermediate": true
                    },
                    "type": "ClipGuideHead",
                    "upsample": "intepolate",
                    "use_dw": true,
                    "with_argmax": true
                },
                "output": [
                    "post_output"
                ],
                "input": [
                    "prep_output",
                    "infer_output"
                ]
            }
        ]
    }
}